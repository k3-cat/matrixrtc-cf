# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
max_line_length = 100
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,jsonc}]
indent_style = tab
indent_size = 2

[package.json]
indent_style = space

[*.yaml]
indent_size = 2

[*.html]
indent_style = tab
indent_size = 2

[*.css]
indent_style = tab
indent_size = 2

[*.{js,ts,mjs,mts,jsx,tsx}]
indent_style = tab
indent_size = 2
